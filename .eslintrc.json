{
  "extends": "next/core-web-vitals",
  "rules": {
    "@next/next/no-img-element": "warn",
    "react/no-unknown-property": ["error", { "ignore": ["jsx", "global"] }],
    "react-hooks/exhaustive-deps": "warn",
    "jsx-a11y/alt-text": "error",
    "no-console": ["warn", { "allow": ["warn", "error"] }]
  }
}
